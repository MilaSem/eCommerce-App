{
  "name": "ecommerce-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint '**/*.{ts,tsx}'",
    "format": "prettier --write --ignore-unknown .",
    "stylelint": "stylelint '**/*.css' --fix",
